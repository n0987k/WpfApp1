<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер пол — информационная система"
        Height="640"
        Width="1080"
        MinHeight="520"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Icon="{DynamicResource AppIconImage}"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource AppSecondaryBackgroundBrush}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="White" CornerRadius="10" VerticalAlignment="Center">
                        <Image Source="{StaticResource AppLogoImage}" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Мастер пол" Style="{StaticResource AppTitleTextStyle}"/>
                        <TextBlock Text="Учёт партнёров, продукции и производства" Opacity="0.72" FontSize="13" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding UserBannerText}"
                               VerticalAlignment="Center"
                               TextAlignment="Right"
                               MaxWidth="420"
                               TextWrapping="Wrap"
                               Margin="0,0,16,0"
                               FontSize="13"
                               Foreground="{StaticResource AppTextBrush}"/>
                    <Button Content="Выйти"
                            Width="110"
                            Height="36"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Click="OnLogoutClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="16,12,16,16"
                    Background="Transparent"
                    BorderThickness="0">
            <TabItem Header="Партнёры" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Обновить" Width="110" Height="36" Style="{StaticResource AppSecondaryButtonStyle}"
                                    Command="{Binding PartnersViewModel.RefreshCommand}"/>
                            <Button Content="Добавить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppPrimaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding PartnersViewModel.AddPartnerCommand}"/>
                            <Button Content="Изменить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding PartnersViewModel.EditPartnerCommand}"/>
                            <Button Content="Удалить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding PartnersViewModel.DeletePartnerCommand}"/>
                            <Button Content="История" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    Command="{Binding PartnersViewModel.ViewHistoryCommand}"/>
                        </StackPanel>
                        <TextBox Grid.Column="1"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 ToolTip="Поиск по названию, директору, телефону, email, адресу"
                                 Text="{Binding PartnersViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,6" Opacity="0.65" FontSize="12"
                               Text="Поиск и фильтрация применяются к списку партнёров без запроса к базе данных."/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding PartnersViewModel.PartnersView}"
                              SelectedItem="{Binding PartnersViewModel.SelectedPartner}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              RowHeaderWidth="0"
                              Style="{StaticResource AppDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Директор" Binding="{Binding DirectorName}" Width="2*"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Продукция" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <TextBlock Text="{Binding ProductsViewModel.UnavailableMessage}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="{Binding ProductsViewModel.IsAvailable, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                    <DockPanel Visibility="{Binding ProductsViewModel.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Обновить" Width="110" Height="36" Style="{StaticResource AppSecondaryButtonStyle}"
                                    Command="{Binding ProductsViewModel.RefreshCommand}"/>
                            <Button Content="Добавить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppPrimaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding ProductsViewModel.AddCommand}"/>
                            <Button Content="Изменить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding ProductsViewModel.EditCommand}"/>
                            <Button Content="Удалить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding ProductsViewModel.DeleteCommand}"/>
                            <Button Content="История реализации" Width="160" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding ProductsViewModel.HistoryCommand}"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding ProductsViewModel.Products}"
                                  SelectedItem="{Binding ProductsViewModel.SelectedProduct}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource AppDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Код" Binding="{Binding Id}" Width="100"/>
                                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="3*"/>
                                <DataGridTextColumn Header="Тип (ID)" Binding="{Binding ProductTypeId}" Width="90"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N2}" Width="100"/>
                                <DataGridTextColumn Header="Артикул" Binding="{Binding ArticleNumber}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Склад и материалы" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <TextBlock Text="{Binding MaterialsCatalog.UnavailableMessage}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="{Binding MaterialsCatalog.IsAvailable, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                    <DockPanel Visibility="{Binding MaterialsCatalog.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Обновить" Width="110" Height="36" Style="{StaticResource AppSecondaryButtonStyle}"
                                    Command="{Binding MaterialsCatalog.RefreshCommand}"/>
                            <Button Content="Добавить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppPrimaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding MaterialsCatalog.AddCommand}"/>
                            <Button Content="Изменить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding MaterialsCatalog.EditCommand}"/>
                            <Button Content="Удалить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding MaterialsCatalog.DeleteCommand}"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding MaterialsCatalog.Items}"
                                  SelectedItem="{Binding MaterialsCatalog.SelectedRow}"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource AppDataGridStyle}"/>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Производство" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <TextBlock Text="{Binding ProductionCatalog.UnavailableMessage}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="{Binding ProductionCatalog.IsAvailable, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                    <DockPanel Visibility="{Binding ProductionCatalog.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Обновить" Width="110" Height="36" Style="{StaticResource AppSecondaryButtonStyle}"
                                    Command="{Binding ProductionCatalog.RefreshCommand}"/>
                            <Button Content="Добавить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppPrimaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding ProductionCatalog.AddCommand}"/>
                            <Button Content="Изменить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding ProductionCatalog.EditCommand}"/>
                            <Button Content="Удалить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding ProductionCatalog.DeleteCommand}"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding ProductionCatalog.Items}"
                                  SelectedItem="{Binding ProductionCatalog.SelectedRow}"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource AppDataGridStyle}"/>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Сотрудники" Padding="12,6">
                <Grid Margin="0,12,0,0">
                    <TextBlock Text="{Binding EmployeesCatalog.UnavailableMessage}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="{Binding EmployeesCatalog.IsAvailable, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                    <DockPanel Visibility="{Binding EmployeesCatalog.IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Обновить" Width="110" Height="36" Style="{StaticResource AppSecondaryButtonStyle}"
                                    Command="{Binding EmployeesCatalog.RefreshCommand}"/>
                            <Button Content="Добавить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppPrimaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding EmployeesCatalog.AddCommand}"/>
                            <Button Content="Изменить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding EmployeesCatalog.EditCommand}"/>
                            <Button Content="Удалить" Width="120" Height="36" Margin="10,0,0,0" Style="{StaticResource AppSecondaryButtonStyle}"
                                    IsEnabled="{Binding IsAdmin}"
                                    Command="{Binding EmployeesCatalog.DeleteCommand}"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding EmployeesCatalog.Items}"
                                  SelectedItem="{Binding EmployeesCatalog.SelectedRow}"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  RowHeaderWidth="0"
                                  Style="{StaticResource AppDataGridStyle}"/>
                    </DockPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
